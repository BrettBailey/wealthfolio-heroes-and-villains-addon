{
  "name": "heroes-villains-addon",
  "version": "0.1.0",
  "private": true,
  "description": "Wealthfolio addon: biggest-moving holdings (heroes/villains) across accounts, live from the addon SDK",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . && npm run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "publish-addon": "node scripts/publish.mjs",
    "check": "node scripts/publish.mjs --check",
    "check:test": "node scripts/publish.mjs --test",
    "check:lint": "node scripts/publish.mjs --lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@wealthfolio/addon-sdk": "^3.6.2",
    "@wealthfolio/ui": "^3.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.7.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.9.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
